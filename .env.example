# Database
DATABASE_URL=postgresql+asyncpg://referee:referee@localhost:5432/referee_tracker

# OpenAI (GPT-4o Vision for call classification)
OPENAI_API_KEY=sk-...

# Euroleague API (public, no key needed for basic endpoints)
EUROLEAGUE_API_BASE=https://api.euroleague.net
EUROLEAGUE_COMPETITION_CODE=E

# Video processing
VIDEO_STORAGE_PATH=/data/videos
FRAME_STORAGE_PATH=/data/frames
# Optional: Youtube/video source credentials
# YDL_COOKIES_FILE=/data/cookies.txt

# App
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# Worker concurrency
INGESTION_WORKERS=4
VIDEO_WORKERS=2
